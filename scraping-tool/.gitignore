# 出力ファイル（任意）
output_test.json
output*.json
result*.json
result*.csv
test_*.json
test_*.md

# data/ の元データ（手動DL。fetch_station_passengers.py が読み、station_passengers.json を生成）
data/*.zip
# 詳細ページ HTML キャッシュ（build_units_cache が生成。再取得で復元可能なためコミットしない）
data/html_cache/
# 新築詳細ページ HTML キャッシュ（shinchiku_detail_enricher が生成。再取得で復元可能なためコミットしない）
data/shinchiku_html_cache/

# results/ はコミット対象（定期実行結果をGitHubで管理）
# results/previous.json は Slack 差分用の一時ファイル（コミットしない）
results/previous.json

# SQLite WAL 補助ファイル
*.db-wal
*.db-shm

# Python
__pycache__/
*.py[cod]
.Python
.venv/
venv/
.env

# HOME'S 詳細ページ HTML キャッシュ（homes_image_backfill 等が生成。再取得で復元可能）
data/homes_html_cache/
# 汎用: 全ソースの HTML キャッシュディレクトリ
data/*_html_cache/

# 異常応答HTMLの保全ダンプ（scraper_common.dump_debug_html が生成。切り分け用の一時ファイル）
data/debug_dumps/

# バックアップファイル（一時退避用。コミットしない）
*.bak
*.backup.json

# enrichment 中間成果物（パイプラインが再生成可能）
enriched-chuko-sumai/

# 過去レポートの死蔵防止（履歴は Git に残る。old/ ディレクトリは作らない）
results/**/old/

# 買い手コンテキスト生成物（generate_buyer_context.py --write が再生成。
# 個人情報を含む Supabase 適用用SQL。コミットせずユーザーがレビューして適用する）
out/
